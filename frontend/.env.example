# Backend API URL
# Local development:
VITE_API_URL=http://localhost:8000
# Production example:
# VITE_API_URL=https://your-backend.koyeb.app

# API Key (optional for development, required if the backend is configured with VALID_API_KEYS)
VITE_API_KEY=dev-key-12345

# Feature Flags (optional)
# VITE_ENABLE_BETTING=true
# VITE_ENABLE_NOTIFICATIONS=false
