# Root level - ignore both backend and frontend build artifacts

# Backend
backend/__pycache__/
backend/*.py[cod]
backend/.venv/
backend/venv/
backend/ENV/
backend/.mypy_cache/
backend/.pytest_cache/
backend/htmlcov/
backend/coverage.xml
backend/*.egg-info/
backend/dist/
backend/build/
backend/.env
backend/.env.local
backend/logs/
backend/data/cache/*.db

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/*.local
frontend/coverage/
frontend/playwright-report/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
