# World Cup Betting Insights CLI - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# BETTING SITES CONFIGURATION
# =============================================================================

# Betano.pt
BETANO_URL=https://www.betano.pt
BETANO_SPORTS_URL=https://www.betano.pt/sport/
BETANO_ENABLED=true
BETANO_RATE_LIMIT=5

# Betclic.pt
BETCLIC_URL=https://www.betclic.pt
BETCLIC_SPORTS_URL=https://www.betclic.pt/futebol-s1/
BETCLIC_ENABLED=true
BETCLIC_RATE_LIMIT=5

# Esc Online
ESC_URL=https://www.esconline.pt
ESC_SPORTS_URL=https://www.esconline.pt/sportsbook/futebol/
ESC_ENABLED=true
ESC_RATE_LIMIT=5

# Solverde.pt
SOLVERDE_URL=https://www.solverde.pt
SOLVERDE_SPORTS_URL=https://www.solverde.pt/apostas-desportivas/futebol/
SOLVERDE_ENABLED=true
SOLVERDE_RATE_LIMIT=5

# Placard.pt
PLACARD_URL=https://www.placard.pt
PLACARD_SPORTS_URL=https://www.placard.pt/jogos-apostas-desportivas/futebol/
PLACARD_ENABLED=true
PLACARD_RATE_LIMIT=5

# NossaAposta.pt (optional)
NOSSAAPOSTA_URL=https://www.nossaaposta.pt
NOSSAAPOSTA_SPORTS_URL=https://www.nossaaposta.pt/apostas-desportivas/futebol/
NOSSAAPOSTA_ENABLED=false
NOSSAAPOSTA_RATE_LIMIT=5

# =============================================================================
# DATA SOURCE API KEYS
# =============================================================================

# FBref (optional - no API key required for web scraping)
FBREF_URL=https://fbref.com/
FBREF_API_KEY=

# Football-Data.org (get free API key at https://www.football-data.org/)
FOOTBALL_DATA_URL=https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# API-Football (optional, get key at https://api-football.com/)
API_FOOTBALL_URL=https://api-football.com/
API_FOOTBALL_API_KEY=

# =============================================================================
# THRESHOLDS & TUNING
# =============================================================================

# Minimum expected value percentage for bet recommendations
MIN_EV_THRESHOLD=5.0

# Minimum confidence percentage for predictions
MIN_CONFIDENCE_THRESHOLD=60.0

# Minimum odds discrepancy vs market average
ODDS_DISCREPANCY_THRESHOLD=10.0

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional log file path (leave empty for console-only logging)
LOG_FILE=

# Use structured JSON logging (useful for log aggregation)
LOG_STRUCTURED=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Rate limiting: max requests per IP per window
RATE_LIMIT_PER_IP=100
RATE_LIMIT_WINDOW_SECONDS=60

# API authentication header name
API_KEY_HEADER=X-API-Key

# Set DEV_MODE=true only for local development; deployed APIs require VALID_API_KEYS.
DEV_MODE=false
VALID_API_KEYS=
# Required for shared production API rate limiting. Use a managed Redis-compatible URL.
RATE_LIMIT_REDIS_URL=
ALLOW_IN_MEMORY_RATE_LIMIT=false

# CORS configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENABLE_CORS=true

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Sentry DSN for error tracking (get at https://sentry.io/)
SENTRY_DSN=

# Prometheus metrics port
PROMETHEUS_PORT=9090

# Enable Prometheus metrics endpoint
ENABLE_METRICS=false

# =============================================================================
# NEWS SOURCES (comma-separated URLs)
# =============================================================================

NEWS_SOURCES=https://www.record.pt/,https://www.abola.pt/,https://www.ojogo.pt/
