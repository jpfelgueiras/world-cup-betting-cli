# Development mode makes API keys optional for local-only use.
# Keep this false for deployed environments.
DEV_MODE=false

# Logging
LOG_LEVEL=INFO
LOG_STRUCTURED=false
LOG_FILE=

# API Configuration
API_KEY_HEADER=X-API-Key
# Required when DEV_MODE=false. Use a high-entropy secret from your host/secret manager.
VALID_API_KEYS=

# CORS
ENABLE_CORS=true
# Local development:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
# Production example (set this to your deployed frontend URL):
# CORS_ORIGINS=https://your-frontend.vercel.app

# Rate Limiting
RATE_LIMIT_PER_IP=100
RATE_LIMIT_WINDOW_SECONDS=60
# Set true only behind a trusted reverse proxy that controls X-Forwarded-For/X-Real-IP.
TRUST_PROXY_HEADERS=false
# Required when DEV_MODE=false unless ALLOW_IN_MEMORY_RATE_LIMIT=true is set for smoke tests.
RATE_LIMIT_REDIS_URL=
ALLOW_IN_MEMORY_RATE_LIMIT=false
RATE_LIMIT_MAX_KEYS=10000

# Analysis Thresholds
MIN_EV_THRESHOLD=5.0
MIN_CONFIDENCE_THRESHOLD=60.0

# Bookmaker URLs (optional, defaults are set in config.py)
# BETANO_URL=https://www.betano.pt
# BETCLIC_URL=https://www.betclic.pt
# SOLVERDE_URL=https://www.solverde.pt

# Monitoring
ENABLE_METRICS=false
SENTRY_DSN=

# Data Sources (optional)
# FBREF_API_KEY=your-fbref-api-key
# FOOTBALL_DATA_API_KEY=
